# LLM Provider — choose one: anthropic | openai | openrouter | bedrock | ollama
LLM_PROVIDER=anthropic

# Optional: override the default model for the selected provider
# Leave empty to use the provider default (see llm_factory.py for defaults)
LLM_MODEL=

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI
OPENAI_API_KEY=sk-your-key-here

# OpenRouter (OpenAI-compatible — supports 200+ models)
OPENROUTER_API_KEY=sk-or-your-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Example models: anthropic/claude-sonnet-4-5 | openai/gpt-4o | google/gemini-2.0-flash

# Amazon Bedrock
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1
# Example models: anthropic.claude-3-5-sonnet-20241022-v2:0 | amazon.nova-pro-v1:0 | meta.llama3-70b-instruct-v1:0

# Ollama (local — requires Ollama running at OLLAMA_BASE_URL)
OLLAMA_BASE_URL=http://localhost:11434
# Example models: llama3.2 | mistral | qwen2.5 | gemma3

# FastAPI
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=change-me-in-production
CORS_ORIGINS=["http://localhost:8501"]

# Streamlit
STREAMLIT_BACKEND_URL=http://localhost:8000
STREAMLIT_SERVER_PORT=8501

# Agent settings
AGENT_MAX_ITERATIONS=5
AGENT_TEMPERATURE=0.7
AGENT_MAX_TOKENS=4096

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
